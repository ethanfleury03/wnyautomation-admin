# WNY Automation Admin staging environment.
# Copy these values into the Vercel Preview environment scoped to the staging branch.

APP_ENV=staging
NEXT_PUBLIC_APP_BASE_URL=https://wnyautomation-admin-git-staging-ethanfleury03s-projects.vercel.app
NEXT_PUBLIC_CLIENT_LOGIN_URL=https://wnyautomation-portal-gateway-git-staging-wny-automation.vercel.app/sign-in?redirect_url=/launch

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PROXY_URL=https://wnyautomation.com/clerk-proxy
NEXT_PUBLIC_CLERK_PROXY_URL=https://wnyautomation.com/clerk-proxy
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in

# Use the same isolated Neon staging branch as gateway and AWP.
DATABASE_URL=postgres://staging-user:staging-password@staging-host/staging-db?sslmode=require
DATABASE_DIRECT_URL=postgres://staging-user:staging-password@staging-host/staging-db?sslmode=require

ADMIN_EMAILS=ethan@wnyautomation.com,ethan.fleuryy@gmail.com
ADMIN_AUDIT_COMPANY_ID=00000000-0000-0000-0000-000000000000

# Required only when running npm run db:seed:staging.
STAGING_SEED_CONFIRM=seed-staging-data
STAGING_OPERATOR_EMAILS=ethan@wnyautomation.com,ethan.fleuryy@gmail.com
STAGING_GATEWAY_AWP_PORTAL_URL=https://wnyautomation-portal-git-staging-wny-automation.vercel.app

# Keep external services sandboxed or unset in staging.
STRIPE_SECRET_KEY=
